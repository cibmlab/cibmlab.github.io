<div class="container" id="i18_people">
    <div class="row m-b-lg">
        <div class="col-lg-12 text-center">
            <div class="navy-line"></div>
            <h1><span data-i18n="people.my_people">People</span></h1>
        </div>
    </div>
    <div class="row">
        {% for people in site.data.index.curpeople %}
            {% assign loopindex = forloop.index | modulo: 2 %}
            {% if forloop.last %}
                {% if forloop.last == forloop.first %}
            <div class="col-sm-6 wow col-sm-offset-3 zoomIn">
                {% else %}
            <div class="col-sm-6 wow {% if loopindex == 1 %} fadeInLeft col-sm-offset-3 {% else %} fadeInRight {% endif %}">
                {% endif %}
            {% else %}
            <div class="col-sm-6 wow {% if loopindex == 1 %} fadeInLeft {% else %} fadeInRight {% endif %}">
            {% endif %}
              <div class="team-member">
                  <img src="{{ people.img | prepend: site.baseurl }}" class="img-responsive img-circle img-small" alt="">
                  <h4>
                  {% if people.url %}
                  <a href="{{ people.url }}" target="_blank"><span class="navy">{{ people.name }}</span></a>
                  {% elsif people.repo %}
                  <a href="https://github.com/{{ people.gh_user }}/{{ people.repo }}" target="_blank"><span class="navy">{{ people.name }}</span></a>
                  {% else %}
                  <span class="navy">{{ people.name }}</span>
                  {% endif %}
                  </h4>
                  <p><span data-i18n="peoples.{{ people.i18n }}">{{ people.desc }}</span></p>
              </div>
          </div>
      {% endfor %}
    </div>

    <div class="row m-b-lg">
        <div class="col-lg-12 text-center">
            <div class="navy-line"></div>
            <h2><span data-i18n="people.my_people">Past members</span></h2>
        </div>
    </div>
    <div class="row">
        {% for people in site.data.index.curpeople %}
            {% assign loopindex = forloop.index | modulo: 2 %}
            {% if forloop.last %}
                {% if forloop.last == forloop.first %}
            <div class="col-sm-6 wow col-sm-offset-3 zoomIn">
                {% else %}
            <div class="col-sm-6 wow {% if loopindex == 1 %} fadeInLeft col-sm-offset-3 {% else %} fadeInRight {% endif %}">
                {% endif %}
            {% else %}
            <div class="col-sm-6 wow {% if loopindex == 1 %} fadeInLeft {% else %} fadeInRight {% endif %}">
            {% endif %}
              <div class="team-member">
                  {% if people.url %}
                  <a href="{{ people.url }}" target="_blank"><span class="navy">{{ people.name }}</span></a>
                  {% else %}
                  <span class="navy">{{ people.name }}</span>
                  {% endif %}
                  </h4>
                  <p><span data-i18n="peoples.{{ people.i18n }}">{{ people.desc }}</span></p>
              </div>
          </div>
      {% endfor %}
    </div>

</div>
<br>
